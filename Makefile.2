# Yetty Build System v2
# Usage: make -f Makefile.2 <target> [PLATFORM=...] [LOGLEVEL=...] [BUILDTYPE=...] [USE_NIX=...]
#
# Targets: build, config, run, test, clean
#
# Variables:
#   PLATFORM  = desktop | webasm | android | android_x86_64 | windows | ios | ios_x86_64
#   LOGLEVEL  = ytrace | yinfo
#   BUILDTYPE = debug | release | asan
#   USE_NIX   = yes | no

# Defaults
PLATFORM  ?= desktop
LOGLEVEL  ?= ytrace
BUILDTYPE ?= release
USE_NIX   ?= no

# Validation
VALID_PLATFORMS := desktop webasm android android_x86_64 windows ios ios_x86_64
VALID_LOGLEVELS := ytrace yinfo
VALID_BUILDTYPES := debug release asan

$(if $(filter $(PLATFORM),$(VALID_PLATFORMS)),,$(error Invalid PLATFORM=$(PLATFORM). Valid: $(VALID_PLATFORMS)))
$(if $(filter $(LOGLEVEL),$(VALID_LOGLEVELS)),,$(error Invalid LOGLEVEL=$(LOGLEVEL). Valid: $(VALID_LOGLEVELS)))
$(if $(filter $(BUILDTYPE),$(VALID_BUILDTYPES)),,$(error Invalid BUILDTYPE=$(BUILDTYPE). Valid: $(VALID_BUILDTYPES)))

# Build directory (includes nix/nonix suffix)
ifeq ($(USE_NIX),yes)
BUILD_DIR := build-$(PLATFORM)-$(LOGLEVEL)-$(BUILDTYPE)-nix
else
BUILD_DIR := build-$(PLATFORM)-$(LOGLEVEL)-$(BUILDTYPE)-nonix
endif

# Path handling: when USE_NIX=yes, inherit nix shell's PATH; otherwise use system paths
ifeq ($(USE_NIX),yes)
PATH_CMD :=
else
SYSTEM_PATH := /opt/emsdk:/opt/emsdk/upstream/emscripten:/usr/local/bin:/usr/bin:/bin
PATH_CMD := $(PATH_CMD)
endif

# Android SDK
export JAVA_HOME ?= /usr/lib/jvm/java-17-openjdk-amd64
export ANDROID_HOME ?= $(HOME)/android-sdk
export ANDROID_SDK_ROOT ?= $(ANDROID_HOME)
export ANDROID_NDK_HOME ?= $(ANDROID_HOME)/ndk/26.1.10909125
export ANDROID_PLATFORM ?= android-26

# Android ABI based on platform
ifeq ($(PLATFORM),android)
ANDROID_ABI := arm64-v8a
else ifeq ($(PLATFORM),android_x86_64)
ANDROID_ABI := x86_64
endif
export ANDROID_ABI

# Parallel jobs
PARALLEL_JOBS ?=
CMAKE_PARALLEL := $(if $(PARALLEL_JOBS),--parallel $(PARALLEL_JOBS),--parallel)

# Build acceleration
USE_DISTCC ?= 0
USE_CCACHE ?= 0
DISTCC_HOSTS ?= localhost 192.168.1.10
export DISTCC_HOSTS

ifeq ($(USE_DISTCC),1)
ifneq ($(shell which distcc 2>/dev/null),)
export CCACHE_PREFIX := distcc
endif
CMAKE_COMPILER_LAUNCHER := -DCMAKE_C_COMPILER_LAUNCHER=ccache -DCMAKE_CXX_COMPILER_LAUNCHER=ccache
else ifeq ($(USE_CCACHE),1)
CMAKE_COMPILER_LAUNCHER := -DCMAKE_C_COMPILER_LAUNCHER=ccache -DCMAKE_CXX_COMPILER_LAUNCHER=ccache
else
CMAKE_COMPILER_LAUNCHER :=
endif

# CMake options
CMAKE := cmake
CMAKE_GENERATOR := -G Ninja

# Build type flags
ifeq ($(BUILDTYPE),release)
CMAKE_BUILDTYPE_FLAGS := -DCMAKE_BUILD_TYPE=Release
else ifeq ($(BUILDTYPE),debug)
CMAKE_BUILDTYPE_FLAGS := -DCMAKE_BUILD_TYPE=Debug
else ifeq ($(BUILDTYPE),asan)
CMAKE_BUILDTYPE_FLAGS := -DCMAKE_BUILD_TYPE=Debug -DCMAKE_CXX_FLAGS="-fsanitize=address -fno-omit-frame-pointer -g" -DCMAKE_C_FLAGS="-fsanitize=address -fno-omit-frame-pointer -g" -DCMAKE_EXE_LINKER_FLAGS="-fsanitize=address"
endif

# Webasm uses MinSizeRel for release
ifeq ($(PLATFORM),webasm)
ifeq ($(BUILDTYPE),release)
CMAKE_BUILDTYPE_FLAGS := -DCMAKE_BUILD_TYPE=MinSizeRel
endif
endif

# Loglevel flags
ifeq ($(LOGLEVEL),ytrace)
CMAKE_LOGLEVEL_FLAGS :=
else ifeq ($(LOGLEVEL),yinfo)
CMAKE_LOGLEVEL_FLAGS := -DYTRACE_ENABLE_YTRACE=0 -DYTRACE_ENABLE_YDEBUG=0
endif

# iOS toolchain
CMAKE_IOS_TOOLCHAIN := -DCMAKE_SYSTEM_NAME=iOS -DCMAKE_OSX_ARCHITECTURES=arm64 -DCMAKE_OSX_DEPLOYMENT_TARGET=15.0 -DYETTY_IOS=ON
CMAKE_IOS_SIMULATOR_TOOLCHAIN := -DCMAKE_SYSTEM_NAME=iOS -DCMAKE_OSX_ARCHITECTURES=x86_64 -DCMAKE_OSX_SYSROOT=iphonesimulator -DCMAKE_OSX_DEPLOYMENT_TARGET=15.0 -DYETTY_IOS=ON

# Platform-specific toolchain flags
ifeq ($(PLATFORM),ios)
CMAKE_PLATFORM_FLAGS := $(CMAKE_IOS_TOOLCHAIN)
else ifeq ($(PLATFORM),ios_x86_64)
CMAKE_PLATFORM_FLAGS := $(CMAKE_IOS_SIMULATOR_TOOLCHAIN)
else
CMAKE_PLATFORM_FLAGS :=
endif

# Nix shell wrapper (use \# to escape hash in flake references)
ifeq ($(USE_NIX),yes)
ifeq ($(PLATFORM),webasm)
NIX_WRAP := nix develop .\#web --command bash -c
else ifeq ($(PLATFORM),android)
NIX_WRAP := nix develop .\#android --command bash -c
else ifeq ($(PLATFORM),android_x86_64)
NIX_WRAP := nix develop .\#android --command bash -c
else
# Desktop/iOS/macOS use default nix shell
NIX_WRAP := nix develop --command bash -c
endif
else
NIX_WRAP := bash -c
endif

# Gradle options for Android
GRADLE_OPTS := --project-cache-dir=../../$(BUILD_DIR)/.gradle

# macOS check for iOS
UNAME_S := $(shell uname -s)
define CHECK_MACOS
	@if [ "$(UNAME_S)" != "Darwin" ]; then \
		echo "ERROR: iOS builds require macOS with Xcode. Current OS: $(UNAME_S)"; \
		exit 1; \
	fi
endef

#=============================================================================
# Default target
#=============================================================================

.PHONY: all
all: help

#=============================================================================
# Config target
#=============================================================================

.PHONY: config
config: _config-$(PLATFORM)

.PHONY: _config-desktop
_config-desktop:
ifeq ($(USE_NIX),yes)
	$(NIX_WRAP) '$(CMAKE) -B $(BUILD_DIR) $(CMAKE_GENERATOR) $(CMAKE_BUILDTYPE_FLAGS) $(CMAKE_LOGLEVEL_FLAGS) $(CMAKE_COMPILER_LAUNCHER)'
else
	$(PATH_CMD) $(CMAKE) -B $(BUILD_DIR) $(CMAKE_GENERATOR) $(CMAKE_BUILDTYPE_FLAGS) $(CMAKE_LOGLEVEL_FLAGS) $(CMAKE_COMPILER_LAUNCHER)
endif
	@ln -sfn $(BUILD_DIR)/compile_commands.json compile_commands.json

.PHONY: _config-webasm
_config-webasm:
ifeq ($(USE_NIX),yes)
	$(NIX_WRAP) 'export EMCC_SKIP_SANITY_CHECK=1 && emcmake cmake -B $(BUILD_DIR) $(CMAKE_GENERATOR) $(CMAKE_BUILDTYPE_FLAGS) $(CMAKE_LOGLEVEL_FLAGS) $(CMAKE_COMPILER_LAUNCHER)'
else
	$(PATH_CMD) bash -c 'export EMCC_SKIP_SANITY_CHECK=1 && emcmake cmake -B $(BUILD_DIR) $(CMAKE_GENERATOR) $(CMAKE_BUILDTYPE_FLAGS) $(CMAKE_LOGLEVEL_FLAGS) $(CMAKE_COMPILER_LAUNCHER)'
endif

.PHONY: _config-android _config-android_x86_64
_config-android _config-android_x86_64:
	@cd $(CURDIR) && ANDROID_ABI=$(ANDROID_ABI) ANDROID_BUILD_DIR=$(CURDIR)/$(BUILD_DIR) bash build-tools/android/build-dawn.sh

.PHONY: _config-windows
_config-windows:
ifeq ($(BUILDTYPE),release)
	cmd.exe //c "build-tools\windows\build.bat release configure"
else
	cmd.exe //c "build-tools\windows\build.bat debug configure"
endif

.PHONY: _config-ios _config-ios_x86_64
_config-ios _config-ios_x86_64:
	$(CHECK_MACOS)
	$(CMAKE) -B $(BUILD_DIR) $(CMAKE_GENERATOR) $(CMAKE_BUILDTYPE_FLAGS) $(CMAKE_LOGLEVEL_FLAGS) $(CMAKE_PLATFORM_FLAGS)

#=============================================================================
# Build target
#=============================================================================

.PHONY: build
build: _build-$(PLATFORM)

.PHONY: _build-desktop
_build-desktop:
	@if [ ! -f "$(BUILD_DIR)/build.ninja" ]; then $(MAKE) -f Makefile.2 config PLATFORM=$(PLATFORM) LOGLEVEL=$(LOGLEVEL) BUILDTYPE=$(BUILDTYPE) USE_NIX=$(USE_NIX); fi
ifeq ($(USE_NIX),yes)
	$(NIX_WRAP) '$(CMAKE) --build $(BUILD_DIR) $(CMAKE_PARALLEL)'
else
	$(PATH_CMD) $(CMAKE) --build $(BUILD_DIR) $(CMAKE_PARALLEL)
endif

.PHONY: _build-webasm
_build-webasm:
	@if [ ! -f "$(BUILD_DIR)/build.ninja" ]; then $(MAKE) -f Makefile.2 config PLATFORM=$(PLATFORM) LOGLEVEL=$(LOGLEVEL) BUILDTYPE=$(BUILDTYPE) USE_NIX=$(USE_NIX); fi
ifeq ($(USE_NIX),yes)
	$(NIX_WRAP) 'cmake --build $(BUILD_DIR) --target yetty $(CMAKE_PARALLEL)'
else
	$(PATH_CMD) cmake --build $(BUILD_DIR) --target yetty $(CMAKE_PARALLEL)
endif
	@cp build-tools/web/index.html build-tools/web/serve.py $(BUILD_DIR)/
	@bash build-tools/jslinux/alpine/build-vfsync.sh $(BUILD_DIR)
	@$(MAKE) -f Makefile.2 _verify-webasm

.PHONY: _build-android _build-android_x86_64
_build-android _build-android_x86_64:
	@$(MAKE) -f Makefile.2 config PLATFORM=$(PLATFORM) LOGLEVEL=$(LOGLEVEL) BUILDTYPE=$(BUILDTYPE) USE_NIX=$(USE_NIX)
ifeq ($(BUILDTYPE),release)
	$(NIX_WRAP) 'cd build-tools/android && USE_CCACHE=$(USE_CCACHE) ANDROID_ABI=$(ANDROID_ABI) ANDROID_BUILD_DIR=$(CURDIR)/$(BUILD_DIR) ./gradlew $(GRADLE_OPTS) assembleRelease'
else
	$(NIX_WRAP) 'cd build-tools/android && USE_CCACHE=$(USE_CCACHE) ANDROID_ABI=$(ANDROID_ABI) ANDROID_BUILD_DIR=$(CURDIR)/$(BUILD_DIR) ./gradlew $(GRADLE_OPTS) assembleDebug'
endif

.PHONY: _build-windows
_build-windows:
ifeq ($(BUILDTYPE),release)
	cmd.exe //c "build-tools\windows\build.bat release"
else
	cmd.exe //c "build-tools\windows\build.bat debug"
endif

.PHONY: _build-ios _build-ios_x86_64
_build-ios _build-ios_x86_64:
	$(CHECK_MACOS)
	@if [ ! -f "$(BUILD_DIR)/build.ninja" ]; then $(MAKE) -f Makefile.2 config PLATFORM=$(PLATFORM) LOGLEVEL=$(LOGLEVEL) BUILDTYPE=$(BUILDTYPE) USE_NIX=$(USE_NIX); fi
	$(CMAKE) --build $(BUILD_DIR) $(CMAKE_PARALLEL)

.PHONY: _verify-webasm
_verify-webasm:
	@echo "=== Post-build webasm verification ==="
	@FAIL=0; \
	for f in yetty.js yetty.wasm yetty.data index.html serve.py \
	         jslinux/vm-bridge.html jslinux/term-bridge.js \
	         vfsync/u/os/yetty-alpine/head; do \
		if [ ! -e "$(BUILD_DIR)/$$f" ]; then \
			echo "MISSING: $$f"; \
			FAIL=1; \
		fi; \
	done; \
	if [ "$$FAIL" -ne 0 ]; then \
		echo "ERROR: Webasm build incomplete — missing artifacts above"; \
		exit 1; \
	fi; \
	echo "All webasm artifacts verified OK"

#=============================================================================
# Run target
#=============================================================================

.PHONY: run
run: build _run-$(PLATFORM)

.PHONY: _run-desktop
_run-desktop:
ifeq ($(BUILDTYPE),asan)
	ASAN_OPTIONS=halt_on_error=0:detect_leaks=1 ./$(BUILD_DIR)/yetty
else
	./$(BUILD_DIR)/yetty
endif

.PHONY: _run-webasm
_run-webasm:
	python3 $(BUILD_DIR)/serve.py 8000 $(BUILD_DIR)

.PHONY: _run-android _run-android_x86_64
_run-android _run-android_x86_64:
ifeq ($(BUILDTYPE),release)
	adb install -r $(BUILD_DIR)/app/outputs/apk/release/app-release.apk
else
	adb install -r $(BUILD_DIR)/app/outputs/apk/debug/app-debug.apk
endif
	adb shell am start -n com.yetty.terminal/android.app.NativeActivity

.PHONY: _run-windows
_run-windows:
	./$(BUILD_DIR)/yetty.exe

.PHONY: _run-ios _run-ios_x86_64
_run-ios _run-ios_x86_64:
	@echo "iOS run not implemented - use Xcode to deploy to device/simulator"

#=============================================================================
# Test target
#=============================================================================

.PHONY: test
test: _test-$(PLATFORM)

.PHONY: _test-desktop
_test-desktop:
	@if [ ! -f "$(BUILD_DIR)/build.ninja" ]; then $(MAKE) -f Makefile.2 config PLATFORM=$(PLATFORM) LOGLEVEL=$(LOGLEVEL) BUILDTYPE=$(BUILDTYPE) USE_NIX=$(USE_NIX); fi
	$(PATH_CMD) $(CMAKE) --build $(BUILD_DIR) --target yetty_tests $(CMAKE_PARALLEL)
	./$(BUILD_DIR)/test/ut/yetty_tests

.PHONY: _test-webasm _test-windows _test-ios _test-ios_x86_64
_test-webasm _test-windows _test-ios _test-ios_x86_64:
	@echo "Tests not implemented for $(PLATFORM)"

.PHONY: _test-android _test-android_x86_64
_test-android _test-android_x86_64: run

#=============================================================================
# Clean target
#=============================================================================

.PHONY: clean
clean:
	rm -rf $(BUILD_DIR)

.PHONY: clean-all
clean-all:
	rm -rf build-*

#=============================================================================
# Help
#=============================================================================

.PHONY: help
help:
	@echo "Yetty Build System v2"
	@echo ""
	@echo "Usage: make -f Makefile.2 <target> [VARIABLE=value ...]"
	@echo ""
	@echo "Targets:"
	@echo "  build     Build the project (default action)"
	@echo "  config    Configure only (cmake)"
	@echo "  run       Build and run"
	@echo "  test      Build and run tests"
	@echo "  clean     Clean current configuration"
	@echo "  clean-all Clean all build directories"
	@echo "  help      Show this help"
	@echo ""
	@echo "Variables:"
	@echo "  PLATFORM   = desktop | webasm | android | android_x86_64 | windows | ios | ios_x86_64"
	@echo "               (default: desktop)"
	@echo "  LOGLEVEL   = ytrace | yinfo"
	@echo "               (default: ytrace)"
	@echo "  BUILDTYPE  = debug | release | asan"
	@echo "               (default: release)"
	@echo "  USE_NIX    = yes | no"
	@echo "               (default: no)"
	@echo ""
	@echo "Examples:"
	@echo "  make -f Makefile.2 build PLATFORM=webasm"
	@echo "  make -f Makefile.2 run PLATFORM=desktop BUILDTYPE=debug"
	@echo "  make -f Makefile.2 build PLATFORM=android USE_NIX=yes"
	@echo "  make -f Makefile.2 test LOGLEVEL=yinfo"
	@echo ""
	@echo "Build acceleration:"
	@echo "  USE_CCACHE=1  Use ccache for local caching"
	@echo "  USE_DISTCC=1  Use ccache + distcc for distributed builds"
