#=============================================================================
# Dawn WebGPU (pre-built)
#=============================================================================

DAWN_VERSION = "20260214.164635"
DAWN_COMMIT = "1a3afc99a7ef7dacaab73b71d44575c4f1bf2dd7"

genrule(
    name = "dawn_download",
    out = "dawn",
    bash = """
        set -e
        mkdir -p "$OUT"
        curl -fsSL "https://github.com/google/dawn/releases/download/v{version}/Dawn-{commit}-ubuntu-latest-Release.tar.gz" | tar -xz -C "$OUT" --strip-components=1
    """.format(version = DAWN_VERSION, commit = DAWN_COMMIT),
    cacheable = True,
    visibility = ["PUBLIC"],
)

cxx_library(
    name = "dawn",
    exported_linker_flags = ["$(location :dawn_download)/lib64/libwebgpu_dawn.a"],
    exported_preprocessor_flags = ["-isystem", "$(location :dawn_download)/include"],
    visibility = ["PUBLIC"],
)

#=============================================================================
# glfw3webgpu (GLFW-WebGPU bridge)
# Header-only usage - just provide the header, source compiled by consumer
#=============================================================================

genrule(
    name = "glfw3webgpu_build",
    out = "install",
    bash = """
        set -e
        mkdir -p "$OUT/include" "$OUT/lib"
        curl -fsSL "https://raw.githubusercontent.com/eliemichel/glfw3webgpu/main/glfw3webgpu.h" -o "$OUT/include/glfw3webgpu.h"
        curl -fsSL "https://raw.githubusercontent.com/eliemichel/glfw3webgpu/main/glfw3webgpu.c" -o "$BUCK_SCRATCH_PATH/glfw3webgpu.c"
        cc -c -fPIC -O2 -w -DWEBGPU_BACKEND_DAWN \
            -I"$OUT/include" \
            -isystem "$(location :glfw_build)/include" \
            -isystem "$(location :dawn_download)/include" \
            "$BUCK_SCRATCH_PATH/glfw3webgpu.c" -o "$BUCK_SCRATCH_PATH/glfw3webgpu.o"
        ar rcs "$OUT/lib/libglfw3webgpu.a" "$BUCK_SCRATCH_PATH/glfw3webgpu.o"
    """,
    cacheable = True,
    visibility = ["PUBLIC"],
)

cxx_library(
    name = "glfw3webgpu",
    exported_linker_flags = ["$(location :glfw3webgpu_build)/lib/libglfw3webgpu.a"],
    exported_preprocessor_flags = ["-isystem", "$(location :glfw3webgpu_build)/include"],
    deps = [
        ":dawn",
        ":glfw",
    ],
    visibility = ["PUBLIC"],
)

