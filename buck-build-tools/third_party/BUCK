#=============================================================================
# howerj/cdb (constant database library - portable implementation)
#=============================================================================

genrule(
    name = "howerj_cdb_build",
    out = "install",
    bash = """
        set -e
        mkdir -p "$OUT/lib" "$OUT/include"
        curl -fsSL "https://github.com/howerj/cdb/archive/refs/heads/master.tar.gz" | tar -xz -C "$BUCK_SCRATCH_PATH"
        CDB="$BUCK_SCRATCH_PATH/cdb-master"
        cc -c -fPIC -O2 -w "$CDB/cdb.c" -o "$BUCK_SCRATCH_PATH/cdb.o"
        ar rcs "$OUT/lib/libcdb.a" "$BUCK_SCRATCH_PATH/cdb.o"
        cp "$CDB/cdb.h" "$OUT/include/"
    """,
    cacheable = True,
    visibility = ["PUBLIC"],
)

cxx_library(
    name = "howerj_cdb",
    exported_linker_flags = ["$(location :howerj_cdb_build)/lib/libcdb.a"],
    exported_preprocessor_flags = ["-isystem", "$(location :howerj_cdb_build)/include"],
    visibility = ["PUBLIC"],
)

