# Third-party dependencies

#=============================================================================
# zlib
#=============================================================================

genrule(
    name = "zlib_build",
    out = "install",
    bash = """
        set -e
        mkdir -p "$OUT"
        curl -fsSL "https://github.com/madler/zlib/releases/download/v1.3.1/zlib-1.3.1.tar.gz" | tar -xz -C "$BUCK_SCRATCH_PATH"
        cmake -S "$BUCK_SCRATCH_PATH/zlib-1.3.1" -B "$BUCK_SCRATCH_PATH/build" \
            -DCMAKE_BUILD_TYPE=Release \
            -DCMAKE_INSTALL_PREFIX="$OUT" \
            -DCMAKE_POSITION_INDEPENDENT_CODE=ON
        cmake --build "$BUCK_SCRATCH_PATH/build" --parallel
        cmake --install "$BUCK_SCRATCH_PATH/build"
    """,
    cacheable = True,
    visibility = ["PUBLIC"],
)

cxx_library(
    name = "zlib",
    exported_linker_flags = ["$(location :zlib_build)/lib/libz.a"],
    exported_preprocessor_flags = ["-isystem", "$(location :zlib_build)/include"],
    visibility = ["PUBLIC"],
)

#=============================================================================
# FreeType
#=============================================================================

genrule(
    name = "freetype_build",
    out = "install",
    bash = """
        set -e
        mkdir -p "$OUT"
        curl -fsSL "https://github.com/freetype/freetype/archive/refs/tags/VER-2-13-2.tar.gz" | tar -xz -C "$BUCK_SCRATCH_PATH"
        cmake -S "$BUCK_SCRATCH_PATH/freetype-VER-2-13-2" -B "$BUCK_SCRATCH_PATH/build" \
            -DCMAKE_BUILD_TYPE=Release \
            -DCMAKE_INSTALL_PREFIX="$OUT" \
            -DCMAKE_POSITION_INDEPENDENT_CODE=ON \
            -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
            -DFT_DISABLE_HARFBUZZ=ON \
            -DFT_DISABLE_BROTLI=ON \
            -DFT_DISABLE_BZIP2=ON \
            -DFT_DISABLE_PNG=ON \
            -DFT_DISABLE_ZLIB=ON \
            -DBUILD_SHARED_LIBS=OFF
        cmake --build "$BUCK_SCRATCH_PATH/build" --parallel
        cmake --install "$BUCK_SCRATCH_PATH/build"
    """,
    cacheable = True,
    visibility = ["PUBLIC"],
)

cxx_library(
    name = "freetype",
    exported_linker_flags = ["$(location :freetype_build)/lib64/libfreetype.a"],
    exported_preprocessor_flags = ["-isystem", "$(location :freetype_build)/include/freetype2"],
    visibility = ["PUBLIC"],
)

