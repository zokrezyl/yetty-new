#=============================================================================
# Default platform (host detection)
#=============================================================================

platform(
    name = "default",
    visibility = ["PUBLIC"],
)

#=============================================================================
# Execution platform with bazel-remote cache enabled
#=============================================================================

remote_cache_execution_platform(
    name = "remote_cache",
    cpu_configuration = host_configuration.cpu,
    os_configuration = host_configuration.os,
    visibility = ["PUBLIC"],
)
