    name = "yetty_macos_x86_64",
    constraint_values = [
        ":macos",
        ":x86_64",
    ],
    visibility = ["PUBLIC"],
)

platform(
    name = "yetty_android_arm64",
    constraint_values = [
        ":android",
        ":arm64",
    ],
    visibility = ["PUBLIC"],
)

platform(
    name = "yetty_android_x86_64",
