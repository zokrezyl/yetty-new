# Build directories — anchor to repo root so we don't accidentally swallow
# files named `build-*` deeper in the tree (e.g. .github/workflows/build-*.yml,
# build-tools/web/build-toybox.sh, build-tools/3rdparty/<lib>/build.sh, …).
/build-*
!/build-tools
tmp/

# IDE/editor
.cache/
.vscode/
compile_commands.json

# Object files and build artifacts
*.o
*.d
*.a
*.so

# QEMU build artifacts
poc/qemu/build-tools/qemu-*/
poc/qemu/build-tools/*.tar.xz

# TinyEMU build artifacts
src/tinyemu/*.o
src/tinyemu/*.d
src/tinyemu/js/
src/tinyemu/Makefile.js
src/tinyemu/Untitled
.buckconfig.local
